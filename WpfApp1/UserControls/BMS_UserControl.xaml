
<UserControl
    x:Class="WpfApp1.UserControls.BMS_UserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:WpfApp1.Convert"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WpfApp1.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="700"
    d:DesignWidth="1200"
    Background="White"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                            <StackPanel>
                                <Border Height="22" Background="#FFD9E8FF">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        FontWeight="Bold"
                                        Text="{TemplateBinding Header}" />
                                </Border>
                                <ContentPresenter />
                            </StackPanel>

                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Width" Value="90" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Background" Value="#ddd" />
            <Setter Property="Foreground" Value="#999" />
            <Setter Property="BorderBrush" Value="#33ffffff" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border
                            x:Name="bor"
                            Background="{TemplateBinding Background}"
                            BorderBrush="#ddd"
                            BorderThickness="0,0,0,3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bor" Property="BorderThickness" Value="0,0,0,3" />
                                <Setter TargetName="bor" Property="BorderBrush" Value="#FF1677FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Foreground" Value="#FF1677FF" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <conv:DivideByThousandConverter x:Key="DivideByThousandConverter" />
        <conv:DivideByThousandWithoutEnumConverter x:Key="DivideByThousandWithoutEnumConverter" />
        <conv:DivideByHundredConverter x:Key="DivideByHundredConverter" />
        <conv:DivideByTenConverter x:Key="DivideByTenConverter" />
        <conv:IntToVisibilityConverter x:Key="IntToVisibilityConverter" />
        <conv:IntToHiddenConverter x:Key="IntToHiddenConverter" />
        <conv:IntToColorConverter x:Key="IntToColorConverter" />
        <conv:IntToColorConverter2 x:Key="IntToColorConverter2" />
        <conv:EnumEqualsConverter x:Key="EnumEqualsConverter" />
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4*" />
            <ColumnDefinition Width="5*" />
            <ColumnDefinition Width="4*" />
            <ColumnDefinition Width="auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <!--  第一行 小标题  -->
        <StackPanel Grid.ColumnSpan="2" Orientation="Horizontal">
            <RadioButton
                Click="ElementView_Click"
                Content="{DynamicResource 概览图}"
                IsChecked="{Binding SelectedMode, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Mode1}" />
            <RadioButton
                Click="ElementSetting_Click"
                Content="{DynamicResource 参数设置}"
                IsChecked="{Binding SelectedMode, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Mode2}" />
            <RadioButton
                Click="ElementSystemSetting_Click"
                Content="{DynamicResource 系统设置}"
                IsChecked="{Binding SelectedMode, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Mode3}" />
            <RadioButton
                Click="HistoryLog_Click"
                Content="{DynamicResource 历史记录}"
                IsChecked="{Binding SelectedMode, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Mode4}" />
            <RadioButton
                Click="RealTimeMonitor_Click"
                Content="{DynamicResource 实时监控}"
                IsChecked="{Binding SelectedMode, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Mode5}" />
            <RadioButton
                Click="AdminView_Click"
                Content="{DynamicResource 前端芯片监控}"
                IsChecked="{Binding SelectedMode, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Mode6}"
                Visibility="{Binding ShowAdmin}" />

            <!--<RadioButton Content="{DynamicResource 软件升级}" />-->
        </StackPanel>

        <!--  第二行 第一列 总览 温度 系统信息  -->
        <Grid Grid.Row="1" Margin="10,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <!--  市电  -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <GroupBox Header="{DynamicResource 总览}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <!--  标题  -->
                        <TextBlock
                            Grid.Row="0"
                            Style="{StaticResource HeaderText}"
                            Text="{DynamicResource 属性}" />
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="1"
                            Style="{StaticResource HeaderText}"
                            Text="{DynamicResource 当前值}" />
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="2"
                            Style="{StaticResource HeaderText}"
                            Text="{DynamicResource 单位}" />
                        <!--  总压  -->
                        <TextBlock
                            Grid.Row="1"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 总压}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            Style="{StaticResource ContentText}"
                            Text="{Binding BMS_VM.MOD_AFECOL_PACKVOL, Converter={StaticResource DivideByHundredConverter}}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="2"
                            Style="{StaticResource ContentText}"
                            Text="V" />

                        <!--  电流  -->
                        <TextBlock
                            Grid.Row="2"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 电流}" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="1"
                            Style="{StaticResource ContentText}"
                            Text="{Binding BMS_VM.MOD_AFECOL_CUR, Converter={StaticResource DivideByHundredConverter}}" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="2"
                            Style="{StaticResource ContentText}"
                            Text="A" />
                        <!--  SOC  -->
                        <TextBlock
                            Grid.Row="3"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource SOC}" />
                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="1"
                            Style="{StaticResource ContentText}"
                            Text="{Binding BMS_VM.MOD_SOC, Converter={StaticResource DivideByHundredConverter}}" />
                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="2"
                            Style="{StaticResource ContentText}"
                            Text="%" />
                        <!--  SOH  -->
                        <TextBlock
                            Grid.Row="4"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource SOH}" />
                        <TextBlock
                            Grid.Row="4"
                            Grid.Column="1"
                            Style="{StaticResource ContentText}"
                            Text="{Binding BMS_VM.MOD_SOH, Converter={StaticResource DivideByHundredConverter}}" />
                        <TextBlock
                            Grid.Row="4"
                            Grid.Column="2"
                            Style="{StaticResource ContentText}"
                            Text="%" />
                        <!--  剩余容量  -->
                        <TextBlock
                            Grid.Row="5"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 剩余容量}" />
                        <TextBlock
                            Grid.Row="5"
                            Grid.Column="1"
                            Style="{StaticResource ContentText}"
                            Text="{Binding BMS_VM.MOD_RES_CAP, Converter={StaticResource DivideByHundredConverter}}" />
                        <TextBlock
                            Grid.Row="5"
                            Grid.Column="2"
                            Style="{StaticResource ContentText}"
                            Text="Ah" />
                        <!--  满充容量  -->
                        <TextBlock
                            Grid.Row="6"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 满充容量}" />
                        <TextBlock
                            Grid.Row="6"
                            Grid.Column="1"
                            Style="{StaticResource ContentText}"
                            Text="{Binding BMS_VM.MOD_FULL_CAP, Converter={StaticResource DivideByHundredConverter}}" />
                        <TextBlock
                            Grid.Row="6"
                            Grid.Column="2"
                            Style="{StaticResource ContentText}"
                            Text="Ah" />
                        <!--  循环次数  -->
                        <TextBlock
                            Grid.Row="7"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 循环次数}" />
                        <TextBlock
                            Grid.Row="7"
                            Grid.Column="1"
                            Style="{StaticResource ContentText}"
                            Text="{Binding BMS_VM.MOD_CYCLECNT}" />
                        <TextBlock
                            Grid.Row="7"
                            Grid.Column="2"
                            Style="{StaticResource ContentText}"
                            Text="次" />


                    </Grid>
                </GroupBox>
            </ScrollViewer>
            <!--  输出  -->
            <GroupBox Grid.Row="1" Header="{DynamicResource 温度}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <!--  电池包温度  -->
                    <TextBlock Style="{StaticResource ContentText}" Text="{DynamicResource 电池包温度}" />
                    <TextBlock
                        Grid.Column="1"
                        Style="{StaticResource ContentText}"
                        Text="{Binding BMS_VM.MOD_ENV_TEMP, Converter={StaticResource DivideByTenConverter}}" />
                    <!--  硬件版本号  -->
                    <TextBlock
                        Grid.Column="2"
                        Style="{StaticResource ContentText}"
                        Text="{DynamicResource MOS温度}" />
                    <TextBlock
                        Grid.Column="3"
                        Style="{StaticResource ContentText}"
                        Text="{Binding BMS_VM.MOD_MOS_TEMP, Converter={StaticResource DivideByTenConverter}}" />
                    <!--  电芯温度1  -->
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="0"
                        Style="{StaticResource ContentText}"
                        Text="{DynamicResource 电芯温度1}" />
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="1"
                        Style="{StaticResource ContentText}"
                        Text="{Binding BMS_VM.MOD_GROUD1_TEMP, Converter={StaticResource DivideByTenConverter}}" />
                    <!--  电芯温度2  -->
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="2"
                        Style="{StaticResource ContentText}"
                        Text="{DynamicResource 电芯温度2}" />
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="3"
                        Style="{StaticResource ContentText}"
                        Text="{Binding BMS_VM.MOD_GROUD2_TEMP, Converter={StaticResource DivideByTenConverter}}" />
                    <!--  电芯温度3  -->
                    <TextBlock
                        Grid.Row="2"
                        Style="{StaticResource ContentText}"
                        Text="{DynamicResource 电芯温度3}" />
                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="1"
                        Style="{StaticResource ContentText}"
                        Text="{Binding BMS_VM.MOD_GROUD3_TEMP, Converter={StaticResource DivideByTenConverter}}" />
                    <!--  电芯温度4  -->
                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="2"
                        Style="{StaticResource ContentText}"
                        Text="{DynamicResource 电芯温度4}" />
                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="3"
                        Style="{StaticResource ContentText}"
                        Text="{Binding BMS_VM.MOD_GROUD4_TEMP, Converter={StaticResource DivideByTenConverter}}" />
                </Grid>
            </GroupBox>
            <!--  系统信息  -->
            <ScrollViewer
                Grid.Row="2"
                VerticalAlignment="Bottom"
                VerticalScrollBarVisibility="Auto">
                <GroupBox FontSize="16" Header="{DynamicResource 系统信息}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <!--  系统时间  -->
                        <TextBlock Style="{StaticResource ContentText}" Text="{DynamicResource 软件版本号}" />
                        <TextBlock
                            Grid.Column="1"
                            Style="{StaticResource ContentText}"
                            Text="{Binding BMS_VM.MOD_SP_SOFTVER}" />
                        <!--  硬件版本号  -->
                        <TextBlock
                            Grid.Column="2"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 硬件版本号}" />
                        <TextBlock
                            Grid.Column="3"
                            Style="{StaticResource ContentText}"
                            Text="{Binding BMS_VM.MOD_SP_HARDVER}" />
                        <!--  版本号  -->
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="2"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource Pack序列号}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="3"
                            Style="{StaticResource ContentText}"
                            Text="{Binding BMS_VM.MOD_SP_SN}" />
                        <!--  发布日期  -->
                        <TextBlock
                            Grid.Row="1"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 出厂日期}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            Style="{StaticResource ContentText}"
                            Text="{Binding BMS_VM.MOD_SP_FACTDATE}" />
                        <!--  机器型号  -->
                        <TextBlock
                            Grid.Row="2"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 厂商}" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="1"
                            Style="{StaticResource ContentText}"
                            Text="{Binding BMS_VM.MOD_SP_FANUFACTURER}" />
                        <!--  机器类型  -->
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="2"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 设备型号}" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="3"
                            Style="{StaticResource ContentText}"
                            Text="{Binding BMS_VM.MOD_SP_DEVICESN}" />

                        <!--  电芯型号  -->
                        <TextBlock
                            Grid.Row="3"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 电芯型号}" />
                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="1"
                            Style="{StaticResource ContentText}"
                            Text="{Binding BMS_VM.MOD_SP_CELLSN}" />
                    </Grid>
                </GroupBox>
            </ScrollViewer>
        </Grid>

        <!--  第二行 第二列 电池图标  -->
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="4*" MaxHeight="500" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" MinHeight="200" />
            </Grid.RowDefinitions>
            <!--  第一行 图标显示  -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <local:BatteryControl
                    Width="250"
                    Height="80"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BatteryValue="{Binding BMS_VM.SOC}" />
                <!--  向下的箭头  -->
                <StackPanel Grid.Row="1">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="../Resource/Fonts/#iconfont"
                        FontSize="25"
                        Foreground="#FF1BD0E4"
                        Text="&#xe62f;"
                        Visibility="{Binding BMS_VM.MOD_AFECOL_CUR, Converter={StaticResource IntToVisibilityConverter}}" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="../Resource/Fonts/#iconfont"
                        FontSize="25"
                        Foreground="#FF1BD0E4"
                        Text="&#xe62f;"
                        Visibility="{Binding BMS_VM.MOD_AFECOL_CUR, Converter={StaticResource IntToVisibilityConverter}}" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="../Resource/Fonts/#iconfont"
                        FontSize="25"
                        Foreground="#FF1BD0E4"
                        Text="&#xe62f;"
                        Visibility="{Binding BMS_VM.MOD_AFECOL_CUR, Converter={StaticResource IntToVisibilityConverter}}" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="../Resource/Fonts/#iconfont"
                        FontSize="25"
                        Foreground="#FF1BD0E4"
                        Text="&#xe62f;"
                        Visibility="{Binding BMS_VM.MOD_AFECOL_CUR, Converter={StaticResource IntToVisibilityConverter}}" />
                </StackPanel>
                <!--  向上的箭头  -->
                <StackPanel Grid.Row="1">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="../Resource/Fonts/#iconfont"
                        FontSize="25"
                        Foreground="#FF1BD0E4"
                        Text="&#xec64;"
                        Visibility="{Binding BMS_VM.MOD_AFECOL_CUR, Converter={StaticResource IntToHiddenConverter}}" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="../Resource/Fonts/#iconfont"
                        FontSize="25"
                        Foreground="#FF1BD0E4"
                        Text="&#xec64;"
                        Visibility="{Binding BMS_VM.MOD_AFECOL_CUR, Converter={StaticResource IntToHiddenConverter}}" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="../Resource/Fonts/#iconfont"
                        FontSize="25"
                        Foreground="#FF1BD0E4"
                        Text="&#xec64;"
                        Visibility="{Binding BMS_VM.MOD_AFECOL_CUR, Converter={StaticResource IntToHiddenConverter}}" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="../Resource/Fonts/#iconfont"
                        FontSize="25"
                        Foreground="#FF1BD0E4"
                        Text="&#xec64;"
                        Visibility="{Binding BMS_VM.MOD_AFECOL_CUR, Converter={StaticResource IntToHiddenConverter}}" />
                </StackPanel>

                <TextBlock
                    Grid.Row="2"
                    HorizontalAlignment="Center"
                    FontFamily="../Resource/Fonts/#iconfont"
                    FontSize="70"
                    Text="&#xe605;" />

            </Grid>
            <GroupBox Grid.Row="1" Header="{DynamicResource 最高与最低电压}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />

                    </Grid.ColumnDefinitions>
                    <!--  最大电压  -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Style="{StaticResource ContentText}" Text="{DynamicResource 最高电压}" />
                    </StackPanel>
                    <TextBlock
                        Grid.Column="1"
                        Foreground="Red"
                        Style="{StaticResource ContentText}"
                        Text="{Binding BMS_VM.MOD_MAXCELL_VOL, Converter={StaticResource DivideByThousandConverter}}" />
                    <!--  最低电压  -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">

                        <TextBlock Style="{StaticResource ContentText}" Text="{DynamicResource 最低电压}" />
                    </StackPanel>
                    <TextBlock
                        Grid.Column="3"
                        Foreground="Orange"
                        Style="{StaticResource ContentText}"
                        Text="{Binding BMS_VM.MOD_MINCELL_VOL, Converter={StaticResource DivideByThousandConverter}}" />
                    <!--  最大电压差  -->
                    <StackPanel Grid.Column="4" Orientation="Horizontal">
                        <TextBlock Style="{StaticResource ContentText}" Text="{DynamicResource 最大电压差}" />
                    </StackPanel>
                    <TextBlock
                        Grid.Column="5"
                        Foreground="Green"
                        Style="{StaticResource ContentText}"
                        Text="{Binding BMS_VM.MOD_CELL_VOLDIFF, Converter={StaticResource DivideByThousandConverter}}" />
                </Grid>

            </GroupBox>
            <!--  单体电压  -->
            <ScrollViewer
                Grid.Row="2"
                Grid.Column="1"
                VerticalScrollBarVisibility="Auto">
                <GroupBox Header="{DynamicResource 单体电压}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                                <ColumnDefinition />
                                <ColumnDefinition />
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                Style="{StaticResource HeaderText}"
                                Text="{DynamicResource 属性}" />
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                Style="{StaticResource HeaderText}"
                                Text="{DynamicResource 均衡}" />
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="2"
                                Style="{StaticResource HeaderText}"
                                Text="{DynamicResource 当前值}" />

                            <TextBlock
                                Grid.Column="3"
                                Style="{StaticResource HeaderText}"
                                Text="{DynamicResource 属性}" />
                            <TextBlock
                                Grid.Column="4"
                                Style="{StaticResource HeaderText}"
                                Text="{DynamicResource 均衡}" />
                            <TextBlock
                                Grid.Column="5"
                                Style="{StaticResource HeaderText}"
                                Text="{DynamicResource 当前值}" />
                        </Grid>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>



                            <!--  电池电压1  -->
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ContentText}" Text="{DynamicResource 电池电压1}" />
                                <Border
                                    Width="15"
                                    Height="15"
                                    Margin="5,0"
                                    Background="{Binding BMS_Setting.JunHen[0], Converter={StaticResource IntToColorConverter}}"
                                    CornerRadius="10" />
                            </StackPanel>

                            <TextBlock
                                Grid.Column="1"
                                Style="{StaticResource ContentText}"
                                Text="{Binding BMS_VM.MOD_CELL1_VOL, Converter={StaticResource DivideByThousandConverter}}" />

                            <!--  电池电压2  -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ContentText}" Text="{DynamicResource 电池电压2}" />
                                <Border
                                    Width="15"
                                    Height="15"
                                    Margin="5,0"
                                    Background="{Binding BMS_Setting.JunHen[1], Converter={StaticResource IntToColorConverter}}"
                                    CornerRadius="10" />
                            </StackPanel>
                            <TextBlock
                                Grid.Column="3"
                                Style="{StaticResource ContentText}"
                                Text="{Binding BMS_VM.MOD_CELL2_VOL, Converter={StaticResource DivideByThousandConverter}}" />
                            <!--  电池电压3  -->
                            <StackPanel
                                Grid.Row="1"
                                Grid.Column="0"
                                Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ContentText}" Text="{DynamicResource 电池电压3}" />
                                <Border
                                    Width="15"
                                    Height="15"
                                    Margin="5,0"
                                    Background="{Binding BMS_Setting.JunHen[2], Converter={StaticResource IntToColorConverter}}"
                                    CornerRadius="10" />
                            </StackPanel>
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="1"
                                Style="{StaticResource ContentText}"
                                Text="{Binding BMS_VM.MOD_CELL3_VOL, Converter={StaticResource DivideByThousandConverter}}" />
                            <!--  电池电压4  -->
                            <StackPanel
                                Grid.Row="1"
                                Grid.Column="2"
                                Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ContentText}" Text="{DynamicResource 电池电压4}" />
                                <Border
                                    Width="15"
                                    Height="15"
                                    Margin="5,0"
                                    Background="{Binding BMS_Setting.JunHen[3], Converter={StaticResource IntToColorConverter}}"
                                    CornerRadius="10" />
                            </StackPanel>
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="3"
                                Style="{StaticResource ContentText}"
                                Text="{Binding BMS_VM.MOD_CELL4_VOL, Converter={StaticResource DivideByThousandConverter}}" />

                        </Grid>
                    </StackPanel>

                </GroupBox>
            </ScrollViewer>
        </Grid>

        <!--  第二行 第三列 状态  -->
        <Grid
            Grid.Row="1"
            Grid.Column="2"
            Margin="10">
            <Grid.RowDefinitions>
