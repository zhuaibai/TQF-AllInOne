<UserControl
    x:Class="WpfApp1.UserControls.BMS_UserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:WpfApp1.Convert"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WpfApp1.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="700"
    d:DesignWidth="1200"
    Background="White"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                            <StackPanel>
                                <Border Height="22" Background="#FFD9E8FF">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        FontWeight="Bold"
                                        Text="{TemplateBinding Header}" />
                                </Border>
                                <ContentPresenter />
                            </StackPanel>

                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Width" Value="90" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Background" Value="#ddd" />
            <Setter Property="Foreground" Value="#999" />
            <Setter Property="BorderBrush" Value="#33ffffff" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border
                            x:Name="bor"
                            Background="{TemplateBinding Background}"
                            BorderBrush="#ddd"
                            BorderThickness="0,0,0,3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bor" Property="BorderThickness" Value="0,0,0,3" />
                                <Setter TargetName="bor" Property="BorderBrush" Value="#FF1677FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Foreground" Value="#FF1677FF" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <conv:DivideByThousandConverter x:Key="DivideByThousandConverter" />
        <conv:DivideByHundredConverter x:Key="DivideByHundredConverter" />
        <conv:DivideByTenConverter x:Key="DivideByTenConverter" />
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4*" />
            <ColumnDefinition Width="5*" />
            <ColumnDefinition Width="4*" />
            <ColumnDefinition Width="auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <!--  第一行  -->
        <StackPanel Grid.ColumnSpan="2" Orientation="Horizontal">
            <RadioButton
                Click="ElementView_Click"
                Content="{DynamicResource 概览图}"
                IsChecked="True" />
            <RadioButton Click="ElementSetting_Click" Content="{DynamicResource 参数设置}" />
            <RadioButton Click="ElementSystemSetting_Click" Content="{DynamicResource 系统设置}" />
            <RadioButton Click="HistoryLog_Click" Content="{DynamicResource 历史记录}" />
            <RadioButton
                Click="AdminView_Click"
                Content="前端芯片监控"
                Visibility="{Binding ShowAdmin}" />
            <!--<RadioButton Content="{DynamicResource 软件升级}" />-->
        </StackPanel>
        <!--  第二行 第一列  -->
        <Grid Grid.Row="1" Margin="10,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition />

            </Grid.RowDefinitions>
            <!--  市电  -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <GroupBox Header="{DynamicResource 总览}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <!--  标题  -->
                        <TextBlock
                            Grid.Row="0"
                            Style="{StaticResource HeaderText}"
                            Text="{DynamicResource 属性}" />
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="1"
                            Style="{StaticResource HeaderText}"
                            Text="{DynamicResource 当前值}" />
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="2"
                            Style="{StaticResource HeaderText}"
                            Text="{DynamicResource 单位}" />
                        <!--  总压  -->
                        <TextBlock
                            Grid.Row="1"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 总压}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            Style="{StaticResource ContentText}"
                            Text="{Binding BMS_VM.MOD_AFECOL_PACKVOL, Converter={StaticResource DivideByHundredConverter}}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="2"
                            Style="{StaticResource ContentText}"
                            Text="V" />

                        <!--  电流  -->
                        <TextBlock
                            Grid.Row="2"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 电流}" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="1"
                            Style="{StaticResource ContentText}"
                            Text="{Binding BMS_VM.MOD_AFECOL_CUR, Converter={StaticResource DivideByHundredConverter}}" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="2"
                            Style="{StaticResource ContentText}"
                            Text="A" />
                        <!--  SOC  -->
                        <TextBlock
                            Grid.Row="3"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource SOC}" />
                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="1"
                            Style="{StaticResource ContentText}"
                            Text="{Binding BMS_VM.MOD_SOC, Converter={StaticResource DivideByHundredConverter}}" />
                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="2"
                            Style="{StaticResource ContentText}"
                            Text="%" />
                        <!--  SOH  -->
                        <TextBlock
                            Grid.Row="4"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource SOH}" />
                        <TextBlock
                            Grid.Row="4"
                            Grid.Column="1"
                            Style="{StaticResource ContentText}"
                            Text="{Binding BMS_VM.MOD_SOH, Converter={StaticResource DivideByHundredConverter}}" />
                        <TextBlock
                            Grid.Row="4"
                            Grid.Column="2"
                            Style="{StaticResource ContentText}"
                            Text="%" />
                        <!--  剩余容量  -->
                        <TextBlock
                            Grid.Row="5"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 剩余容量}" />
                        <TextBlock
                            Grid.Row="5"
                            Grid.Column="1"
                            Style="{StaticResource ContentText}"
                            Text="{Binding BMS_VM.MOD_RES_CAP, Converter={StaticResource DivideByHundredConverter}}" />
                        <TextBlock
                            Grid.Row="5"
                            Grid.Column="2"
                            Style="{StaticResource ContentText}"
                            Text="Ah" />
                        <!--  满充容量  -->
                        <TextBlock
                            Grid.Row="6"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 满充容量}" />
                        <TextBlock
                            Grid.Row="6"
                            Grid.Column="1"
                            Style="{StaticResource ContentText}"
                            Text="{Binding BMS_VM.MOD_FULL_CAP, Converter={StaticResource DivideByHundredConverter}}" />
                        <TextBlock
                            Grid.Row="6"
                            Grid.Column="2"
                            Style="{StaticResource ContentText}"
                            Text="Ah" />
                        <!--  循环次数  -->
                        <TextBlock
                            Grid.Row="7"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 循环次数}" />
                        <TextBlock
                            Grid.Row="7"
                            Grid.Column="1"
                            Style="{StaticResource ContentText}"
                            Text="{Binding BMS_VM.MOD_CYCLECNT}" />
                        <TextBlock
                            Grid.Row="7"
                            Grid.Column="2"
                            Style="{StaticResource ContentText}"
                            Text="次" />


                    </Grid>
                </GroupBox>
            </ScrollViewer>
            <!--  输出  -->
            <GroupBox Grid.Row="1" Header="{DynamicResource 温度}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <!--  电池包温度  -->
                    <TextBlock Style="{StaticResource ContentText}" Text="{DynamicResource 电池包温度}" />
                    <TextBlock
                        Grid.Column="1"
                        Style="{StaticResource ContentText}"
                        Text="{Binding BMS_VM.MOD_ENV_TEMP, Converter={StaticResource DivideByTenConverter}}" />
                    <!--  硬件版本号  -->
                    <TextBlock
                        Grid.Column="2"
                        Style="{StaticResource ContentText}"
                        Text="{DynamicResource MOS温度}" />
                    <TextBlock
                        Grid.Column="3"
                        Style="{StaticResource ContentText}"
                        Text="{Binding BMS_VM.MOD_MOS_TEMP, Converter={StaticResource DivideByTenConverter}}" />
                    <!--  电芯温度1  -->
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="0"
                        Style="{StaticResource ContentText}"
                        Text="{DynamicResource 电芯温度1}" />
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="1"
                        Style="{StaticResource ContentText}"
                        Text="{Binding BMS_VM.MOD_GROUD1_TEMP, Converter={StaticResource DivideByTenConverter}}" />
                    <!--  电芯温度2  -->
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="2"
                        Style="{StaticResource ContentText}"
                        Text="{DynamicResource 电芯温度2}" />
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="3"
                        Style="{StaticResource ContentText}"
                        Text="{Binding BMS_VM.MOD_GROUD2_TEMP, Converter={StaticResource DivideByTenConverter}}" />
                    <!--  电芯温度3  -->
                    <TextBlock
                        Grid.Row="2"
                        Style="{StaticResource ContentText}"
                        Text="{DynamicResource 电芯温度3}" />
                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="1"
                        Style="{StaticResource ContentText}"
                        Text="{Binding BMS_VM.MOD_GROUD3_TEMP, Converter={StaticResource DivideByTenConverter}}" />
                    <!--  电芯温度4  -->
                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="2"
                        Style="{StaticResource ContentText}"
                        Text="{DynamicResource 电芯温度4}" />
                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="3"
                        Style="{StaticResource ContentText}"
                        Text="{Binding BMS_VM.MOD_GROUD4_TEMP, Converter={StaticResource DivideByTenConverter}}" />



                </Grid>
            </GroupBox>
            <!--  系统信息  -->
            <ScrollViewer
                Grid.Row="2"
                VerticalAlignment="Bottom"
                VerticalScrollBarVisibility="Auto">
                <GroupBox FontSize="16" Header="{DynamicResource 系统信息}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <!--  系统时间  -->
                        <TextBlock Style="{StaticResource ContentText}" Text="{DynamicResource 软件版本号}" />
                        <TextBlock
                            Grid.Column="1"
                            Style="{StaticResource ContentText}"
                            Text="{Binding BMS_VM.MOD_SP_SOFTVER}" />
                        <!--  硬件版本号  -->
                        <TextBlock
                            Grid.Column="2"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 硬件版本号}" />
                        <TextBlock
                            Grid.Column="3"
                            Style="{StaticResource ContentText}"
                            Text="{Binding BMS_VM.MOD_SP_HARDVER}" />
                        <!--  版本号  -->
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="2"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource Pack序列号}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="3"
                            Style="{StaticResource ContentText}"
                            Text="{Binding BMS_VM.MOD_SP_SN}" />
                        <!--  发布日期  -->
                        <TextBlock
                            Grid.Row="1"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 出厂日期}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            Style="{StaticResource ContentText}"
                            Text="{Binding BMS_VM.MOD_SP_FACTDATE}" />
                        <!--  机器型号  -->
                        <TextBlock
                            Grid.Row="2"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 厂商}" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="1"
                            Style="{StaticResource ContentText}"
                            Text="{Binding BMS_VM.MOD_SP_FANUFACTURER}" />
                        <!--  机器类型  -->
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="2"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 设备型号}" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="3"
                            Style="{StaticResource ContentText}"
                            Text="{Binding BMS_VM.MOD_SP_DEVICESN}" />

                        <!--  电芯型号  -->

                        <TextBlock
                            Grid.Row="3"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 电芯型号}" />
                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="1"
                            Style="{StaticResource ContentText}"
                            Text="{Binding BMS_VM.MOD_SP_CELLSN}" />

                    </Grid>
                </GroupBox>
            </ScrollViewer>


        </Grid>
        <!--  第二行 第二列  -->
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="4*" MaxHeight="500" />
                <RowDefinition Height="auto" MinHeight="200" />
            </Grid.RowDefinitions>
            <!--  第一行 图标显示  -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <!--  太阳能发电(左上)  -->
                <Grid Grid.Column="0">

                    <local:RingUC
                        FontSize="12"
                        PercentValue="{Binding MPPTTotalPwr}"
                        icon="&#xe809;" />
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Orientation="Horizontal">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Text="{Binding HPV_PDF.PVPwr}" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            FontSize="10"
                            Text="w" />
                    </StackPanel>

                </Grid>
                <!--  市电（右上）  -->
                <Grid Grid.Row="0" Grid.Column="2">

                    <local:RingUC
                        FontSize="12"
                        PercentValue="{Binding ACTotalPwr}"
                        icon="&#xe61c;" />

                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Orientation="Horizontal">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Text="{Binding HGRID_GB.ACPower}" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            FontSize="10"
                            Text="w" />
                    </StackPanel>
                </Grid>
                <!--  光伏发电到逆变器箭头  -->
                <Grid Grid.Row="1">

                    <!--  向下箭头  -->
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        FontFamily="../Resource/Fonts/#iconfont"
                        FontSize="15"
                        Foreground="#FF1BD0E4"
                        Text="&#xe62f;"
                        Visibility="{Binding HSTS2_HPVINV08.PVStatus}" />

                    <!--  向右箭头  -->
                    <StackPanel
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">

                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec62;"
                            Visibility="{Binding HSTS2_HPVINV08.PVStatus}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec62;"
                            Visibility="{Binding HSTS2_HPVINV08.PVStatus}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec62;"
                            Visibility="{Binding HSTS2_HPVINV08.PVStatus}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec62;"
                            Visibility="{Binding HSTS2_HPVINV08.PVStatus}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec62;"
                            Visibility="{Binding HSTS2_HPVINV08.PVStatus}" />
                    </StackPanel>

                </Grid>

                <!--  电池到逆变器箭头  -->
                <Grid Grid.Row="2" Grid.Column="1">

                    <!--  向下的箭头  -->
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Orientation="Vertical">
                        <TextBlock
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xe62f;"
                            Visibility="{Binding HSTS2_HPVINV08.BattChgFlag}" />
                        <TextBlock
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xe62f;"
                            Visibility="{Binding HSTS2_HPVINV08.BattChgFlag}" />
                        <TextBlock
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xe62f;"
                            Visibility="{Binding HSTS2_HPVINV08.BattChgFlag}" />
                        <TextBlock
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xe62f;"
                            Visibility="{Binding HSTS2_HPVINV08.BattChgFlag}" />
                        <TextBlock
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xe62f;"
                            Visibility="{Binding HSTS2_HPVINV08.BattChgFlag}" />
                        <TextBlock
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xe62f;"
                            Visibility="{Binding HSTS2_HPVINV08.BattChgFlag}" />

                    </StackPanel>
                    <!--  向上的箭头  -->
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Orientation="Vertical">
                        <TextBlock
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec64;"
                            Visibility="{Binding HSTS2_HPVINV08.BattDisFlag}" />
                        <TextBlock
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec64;"
                            Visibility="{Binding HSTS2_HPVINV08.BattDisFlag}" />
                        <TextBlock
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec64;"
                            Visibility="{Binding HSTS2_HPVINV08.BattDisFlag}" />
                        <TextBlock
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec64;"
                            Visibility="{Binding HSTS2_HPVINV08.BattDisFlag}" />
                        <TextBlock
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec64;"
                            Visibility="{Binding HSTS2_HPVINV08.BattDisFlag}" />
                        <TextBlock
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec64;"
                            Visibility="{Binding HSTS2_HPVINV08.BattDisFlag}" />

                    </StackPanel>
                    <!--  向右的箭头  -->
                    <StackPanel
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">

                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec62;"
                            Visibility="{Binding HSTS2_HPVINV08.BattDisFlag}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec62;"
                            Visibility="{Binding HSTS2_HPVINV08.BattDisFlag}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec62;"
                            Visibility="{Binding HSTS2_HPVINV08.BattDisFlag}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec62;"
                            Visibility="{Binding HSTS2_HPVINV08.BattDisFlag}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec62;"
                            Visibility="{Binding HSTS2_HPVINV08.BattDisFlag}" />
                    </StackPanel>
                    <!--  向左的箭头  -->
                    <StackPanel
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">

                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec63;"
                            Visibility="{Binding HSTS2_HPVINV08.BattChgFlag}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec63;"
                            Visibility="{Binding HSTS2_HPVINV08.BattChgFlag}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec63;"
                            Visibility="{Binding HSTS2_HPVINV08.BattChgFlag}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec63;"
                            Visibility="{Binding HSTS2_HPVINV08.BattChgFlag}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec63;"
                            Visibility="{Binding HSTS2_HPVINV08.BattChgFlag}" />
                    </StackPanel>

                </Grid>

                <!--  逆变器到市电箭头  -->
                <Grid Grid.Row="0" Grid.Column="1">

                    <!--  向下的箭头  -->
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Orientation="Vertical">
                        <TextBlock
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xe62f;"
                            Visibility="{Binding HSTS2_HPVINV08.ACStatusIn}" />
                        <TextBlock
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xe62f;"
                            Visibility="{Binding HSTS2_HPVINV08.ACStatusIn}" />
                        <TextBlock
                            FontFamily="../Resource/Fonts/#iconfont"
