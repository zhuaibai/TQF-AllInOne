                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec62;"
                            Visibility="{Binding HSTS2_HPVINV08.PVStatus}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec62;"
                            Visibility="{Binding HSTS2_HPVINV08.PVStatus}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec62;"
                            Visibility="{Binding HSTS2_HPVINV08.PVStatus}" />
                    </StackPanel>

                </Grid>

                <!--  电池到逆变器箭头  -->
                <Grid Grid.Row="2" Grid.Column="1">

                    <!--  向下的箭头  -->
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Orientation="Vertical">
                        <TextBlock
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xe62f;"
                            Visibility="{Binding HSTS2_HPVINV08.BattChgFlag}" />
                        <TextBlock
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xe62f;"
                            Visibility="{Binding HSTS2_HPVINV08.BattChgFlag}" />
