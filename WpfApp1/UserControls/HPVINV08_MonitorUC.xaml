                    </StackPanel>
                    <!--  向左的箭头  -->
                    <StackPanel
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">

                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
