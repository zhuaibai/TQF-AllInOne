<UserControl
    x:Class="WpfApp1.UserControls.HPVINV08_MonitorUC"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WpfApp1.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="700"
    d:DesignWidth="1200"
    Background="White"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                            <StackPanel>
                                <Border Height="22" Background="#FFD9E8FF">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        FontWeight="Bold"
                                        Text="{TemplateBinding Header}" />
                                </Border>
                                <ContentPresenter />
                            </StackPanel>

                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Width" Value="90" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Background" Value="#ddd" />
            <Setter Property="Foreground" Value="#999" />
            <Setter Property="BorderBrush" Value="#33ffffff" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border
                            x:Name="bor"
                            Background="{TemplateBinding Background}"
                            BorderBrush="#ddd"
                            BorderThickness="0,0,0,3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bor" Property="BorderThickness" Value="0,0,0,3" />
                                <Setter TargetName="bor" Property="BorderBrush" Value="#FF1677FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Foreground" Value="#FF1677FF" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4*" />
            <ColumnDefinition Width="5*" />
            <ColumnDefinition Width="4*" />
            <ColumnDefinition Width="auto" />

        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <!--  第一行  -->
        <StackPanel Orientation="Horizontal">
            <RadioButton
                Click="ElementView_Click"
                Content="{DynamicResource 概览图}"
                IsChecked="True" />
            <RadioButton Click="ElementSetting_Click" Content="{DynamicResource 参数设置}" />
            <Button Content="{DynamicResource 自动保存数据}" Style="{DynamicResource BtnStyle0}"  Command="{Binding DR_Monitor.HPVINV08SaveCommand}">
            </Button>
        </StackPanel>
        <!--  第二行 第一列  -->
        <Grid Grid.Row="1" Margin="10,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <!--  市电  -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <GroupBox Header="{DynamicResource 市电}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <!--  标题  -->
                        <TextBlock
                            Grid.Row="0"
                            Style="{StaticResource HeaderText}"
                            Text="{DynamicResource 属性}" />
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="1"
                            Style="{StaticResource HeaderText}"
                            Text="{DynamicResource 当前值}" />
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="2"
                            Style="{StaticResource HeaderText}"
                            Text="{DynamicResource 单位}" />
                        <!--  市电电压  -->
                        <TextBlock
                            Grid.Row="1"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 市电电压}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            Style="{StaticResource ContentText}"
                            Text="{Binding HGRID_GB.MainsVoltage}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="2"
                            Style="{StaticResource ContentText}"
                            Text="V" />

                        <!--  市电频率  -->
                        <TextBlock
                            Grid.Row="2"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 市电频率}" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="1"
                            Style="{StaticResource ContentText}"
                            Text="{Binding HGRID_GB.MainsFrequency}" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="2"
                            Style="{StaticResource ContentText}"
                            Text="Hz" />
                        <!--  市电功率  -->
                        <TextBlock
                            Grid.Row="3"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 市电功率}" />
                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="1"
                            Style="{StaticResource ContentText}"
                            Text="{Binding HGRID_GB.ACPower}" />
                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="2"
                            Style="{StaticResource ContentText}"
                            Text="W" />


                    </Grid>
                </GroupBox>
            </ScrollViewer>
            <!--  输出  -->
            <GroupBox Grid.Row="1" Header="{DynamicResource 输出}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <!--  标题  -->
                    <TextBlock
                        Grid.Row="0"
                        Style="{StaticResource HeaderText}"
                        Text="{DynamicResource 属性}" />
                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="1"
                        Style="{StaticResource HeaderText}"
                        Text="{DynamicResource 当前值}" />
                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="2"
                        Style="{StaticResource HeaderText}"
                        Text="{DynamicResource 单位}" />

                    <!--  输出电压  -->
                    <TextBlock
                        Grid.Row="1"
                        Style="{StaticResource ContentText}"
                        Text="{DynamicResource 输出电压}" />
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="1"
                        Style="{StaticResource ContentText}"
                        Text="{Binding HOP_PDF.OutVolt}" />
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="2"
                        Style="{StaticResource ContentText}"
                        Text="V" />
                    <!--  输出频率  -->
                    <TextBlock
                        Grid.Row="2"
                        Style="{StaticResource ContentText}"
                        Text="{DynamicResource 输出频率}" />
                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="1"
                        Style="{StaticResource ContentText}"
                        Text="{Binding HOP_PDF.OutFreq}" />
                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="2"
                        Style="{StaticResource ContentText}"
                        Text="Hz" />
                    <!--  视在功率  -->
                    <TextBlock
                        Grid.Row="3"
                        Style="{StaticResource ContentText}"
                        Text="{DynamicResource 视在功率}" />
                    <TextBlock
                        Grid.Row="3"
                        Grid.Column="1"
                        Style="{StaticResource ContentText}"
                        Text="{Binding HOP_PDF.ApparentPwr}" />
                    <TextBlock
                        Grid.Row="3"
                        Grid.Column="2"
                        Style="{StaticResource ContentText}"
                        Text="VA
" />
                    <!--  有功功率  -->
                    <TextBlock
                        Grid.Row="4"
                        Style="{StaticResource ContentText}"
                        Text="{DynamicResource 有功功率}" />
                    <TextBlock
                        Grid.Row="4"
                        Grid.Column="1"
                        Style="{StaticResource ContentText}"
                        Text="{Binding HOP_PDF.ActivePwr}" />
                    <TextBlock
                        Grid.Row="4"
                        Grid.Column="2"
                        Style="{StaticResource ContentText}"
                        Text="W" />
                    <!--  负载百分比  -->
                    <TextBlock
                        Grid.Row="5"
                        Style="{StaticResource ContentText}"
                        Text="{DynamicResource 负载百分比}" />
                    <TextBlock
                        Grid.Row="5"
                        Grid.Column="1"
                        Style="{StaticResource ContentText}"
                        Text="{Binding HOP_PDF.LoadPercent}" />
                    <TextBlock
                        Grid.Row="5"
                        Grid.Column="2"
                        Style="{StaticResource ContentText}"
                        Text="%" />
                    <!--  调零功率  -->
                    <TextBlock
                        Grid.Row="6"
                        Style="{StaticResource ContentText}"
                        Text="{DynamicResource 调零功率}" />
                    <TextBlock
                        Grid.Row="6"
                        Grid.Column="1"
                        Style="{StaticResource ContentText}"
                        Text="{Binding HEEP3_PDF.ZeroAdjPwr}" />
                    <TextBlock
                        Grid.Row="6"
                        Grid.Column="2"
                        Style="{StaticResource ContentText}"
                        Text="W" />

                    <!--  CT电流  -->
                    <TextBlock
                        Grid.Row="7"
                        Style="{StaticResource ContentText}"
                        Text="{DynamicResource CT电流}" />
                    <TextBlock
                        Grid.Row="7"
                        Grid.Column="1"
                        Style="{StaticResource ContentText}"
                        Text="{Binding HCTMSG1_PDF.CTCurr}" />
                    <TextBlock
                        Grid.Row="7"
                        Grid.Column="2"
                        Style="{StaticResource ContentText}"
                        Text="A" />
                    <!--  CT功率  -->
                    <TextBlock
                        Grid.Row="8"
                        Style="{StaticResource ContentText}"
                        Text="{DynamicResource CT功率}" />
                    <TextBlock
                        Grid.Row="8"
                        Grid.Column="1 "
                        Style="{StaticResource ContentText}"
                        Text="{Binding HCTMSG1_PDF.CTPwr}" />
                    <TextBlock
                        Grid.Row="8"
                        Grid.Column="2"
                        Style="{StaticResource ContentText}"
                        Text="W" />



                </Grid>
            </GroupBox>
            <!--  系统信息  -->
            <ScrollViewer
                Grid.Row="2"
                VerticalAlignment="Bottom"
                VerticalScrollBarVisibility="Auto">
                <GroupBox FontSize="16" Header="{DynamicResource 系统信息}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />

                        </Grid.RowDefinitions>
                        <!--  系统时间  -->
                        <TextBlock Style="{StaticResource ContentText}" Text="{DynamicResource 系统时间}" />
                        <TextBlock
                            Grid.Column="2"
                            Grid.ColumnSpan="2"
                            Style="{StaticResource ContentText}"
                            Text="{Binding HGEN.SystemTime}" />
                        <!--  版本号  -->
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="2"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 版本号}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="3"
                            Style="{StaticResource ContentText}"
                            Text="{Binding HIMSG1.Version}" />
                        <!--  发布日期  -->
                        <TextBlock
                            Grid.Row="1"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 发布日期}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            Style="{StaticResource ContentText}"
                            Text="{Binding HIMSG1.ReleaseDate}" />
                        <!--  机器型号  -->
                        <TextBlock
                            Grid.Row="2"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 机器型号}" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="1"
                            Style="{StaticResource ContentText}"
                            Text="{Binding MachineModel}" />
                        <!--  机器类型  -->
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="2"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 机器类型}" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="3"
                            Style="{StaticResource ContentText}"
                            Text="{Binding MachineType}" />

                    </Grid>
                </GroupBox>
            </ScrollViewer>


        </Grid>
        <!--  第二行 第二列  -->
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="4*" MaxHeight="500" />
                <RowDefinition Height="auto" MinHeight="200" />
            </Grid.RowDefinitions>
            <!--  第一行 图标显示  -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <!--  太阳能发电(左上)  -->
                <Grid Grid.Column="0">

                    <local:RingUC
                        FontSize="12"
                        PercentValue="{Binding MPPTTotalPwr}"
                        icon="&#xe809;" />
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Orientation="Horizontal">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Text="{Binding HPV_PDF.PVPwr}" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            FontSize="10"
                            Text="w" />
                    </StackPanel>

                </Grid>
                <!--  市电（右上）  -->
                <Grid Grid.Row="0" Grid.Column="2">

                    <local:RingUC
                        FontSize="12"
                        PercentValue="{Binding ACTotalPwr}"
                        icon="&#xe61c;" />

                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Orientation="Horizontal">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Text="{Binding HGRID_GB.ACPower}" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            FontSize="10"
                            Text="w" />
                    </StackPanel>
                </Grid>
                <!--  光伏发电到逆变器箭头  -->
                <Grid Grid.Row="1">

                    <!--  向下箭头  -->
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        FontFamily="../Resource/Fonts/#iconfont"
                        FontSize="15"
                        Foreground="#FF1BD0E4"
                        Text="&#xe62f;"
                        Visibility="{Binding HSTS2_HPVINV08.PVStatus}" />

                    <!--  向右箭头  -->
                    <StackPanel
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">

                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec62;"
                            Visibility="{Binding HSTS2_HPVINV08.PVStatus}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec62;"
                            Visibility="{Binding HSTS2_HPVINV08.PVStatus}" />
                        <TextBlock
