                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec63;"
                            Visibility="{Binding HSTS2_HPVINV08.BattChgFlag}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec63;"
                            Visibility="{Binding HSTS2_HPVINV08.BattChgFlag}" />
                    </StackPanel>

                </Grid>

                <!--  逆变器到市电箭头  -->
                <Grid Grid.Row="0" Grid.Column="1">

                    <!--  向下的箭头  -->
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Orientation="Vertical">
                        <TextBlock
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
