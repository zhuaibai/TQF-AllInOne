                            VerticalAlignment="Center"
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec62;"
                            Visibility="{Binding HSTS2_HPVINV08.BattDisFlag}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec62;"
                            Visibility="{Binding HSTS2_HPVINV08.BattDisFlag}" />
                        <TextBlock
