<UserControl
    x:Class="WpfApp1.UserControls.LB6_MonitorUC"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WpfApp1.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Background="White"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                            <StackPanel>
                                <Border Height="22" Background="#FFD9E8FF">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        FontWeight="Bold"
                                        Text="{TemplateBinding Header}" />
                                </Border>

                                <ContentPresenter />


                            </StackPanel>

                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Width" Value="90" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Background" Value="#ddd" />
            <Setter Property="Foreground" Value="#999" />
            <Setter Property="BorderBrush" Value="#33ffffff" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border
                            x:Name="bor"
                            Background="{TemplateBinding Background}"
                            BorderBrush="#ddd"
                            BorderThickness="0,0,0,3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bor" Property="BorderThickness" Value="0,0,0,3" />
                                <Setter TargetName="bor" Property="BorderBrush" Value="#FF1677FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Foreground" Value="#FF1677FF" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4*" />
            <ColumnDefinition Width="5*" />
            <ColumnDefinition Width="4*" />
            <ColumnDefinition Width="auto" />

        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <!--  第一行  -->
        <StackPanel Orientation="Horizontal">
            <RadioButton
                Click="ElementView_Click"
                Content="{DynamicResource 概览图}"
                IsChecked="True" />
            <RadioButton Click="ElementSetting_Click" Content="{DynamicResource 参数设置}" />
            <Button Content="{DynamicResource 自动保存数据}" Style="{DynamicResource BtnStyle0}"  Command="{Binding DR_Monitor.LB6SaveCommand}">
            </Button>
        </StackPanel>
        <!--  第二行 第一列  -->
        <Grid Grid.Row="1" Margin="10,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <!--  并网功能配置  -->
            <!--  电池  -->
            <GroupBox Grid.Row="0" Header="{DynamicResource 电池}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <!--  电池节数  -->

                    <TextBlock
                        Grid.Row="0"
                        Style="{StaticResource ContentText}"
                        Text="{DynamicResource 电池节数}" />
                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="1"
                        Style="{StaticResource ContentText}"
                        Text="{Binding HBAT_VQ2.BattCells}" />
                    <!--  电池电流  -->
                    <!--<TextBlock
                    Grid.Row="0"
                    Style="{StaticResource ContentText}"
                    Text="{DynamicResource 电池电流}" />
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="1"
                    Style="{StaticResource ContentText}"
                    Text="{Binding HBAT_VQ.BatCurr}" />-->
                    <!--  电池电压  -->
                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="2"
                        Style="{StaticResource ContentText}"
                        Text="{DynamicResource 电池电压}" />
                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="3"
                        Style="{StaticResource ContentText}"
                        Text="{Binding HBAT_VQ2.BattVolt, StringFormat={}{0}V}" />
                    <!--  电池容量  -->
                    <TextBlock
                        Grid.Row="1"
                        Style="{StaticResource ContentText}"
                        Text="{DynamicResource 电池容量}" />
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="1"
                        Style="{StaticResource ContentText}"
                        Text="{Binding HBAT_VQ2.BattCapacity, StringFormat={}{0}%}" />
                    <!--  电池类型  -->
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="2"
                        Style="{StaticResource ContentText}"
                        Text="{DynamicResource 电池类型}" />
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="3"
                        Style="{StaticResource ContentText}"
                        Text="{Binding HEEP1_LB6.BatteryType}" />


                    <!--  电池充电电流  -->
                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="0"
                        Style="{StaticResource ContentText}"
                        Text="{DynamicResource 电池充电电流}" />
                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="1"
                        Style="{StaticResource ContentText}"
                        Text="{Binding HBAT_VQ2.BattChgCurr, StringFormat={}{0}A}" />



                    <!--  电池放电电流  -->
                    <!--<TextBlock
                        Grid.Row="2"
                        Grid.Column="2"
                        Style="{StaticResource ContentText}"
                        Text="{DynamicResource 电池放电电流}" />
                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="3"
                        Style="{StaticResource ContentText}"
                        Text="{Binding HBAT_VQ2.BattDisCurr, StringFormat={}{0}A}" />-->

                </Grid>
            </GroupBox>
            <!--  市电  -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <GroupBox Grid.Row="2" Header="{DynamicResource 市电}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <!--  标题  -->
                        <TextBlock
                            Grid.Row="0"
                            Style="{StaticResource HeaderText}"
                            Text="{DynamicResource 属性}" />
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="1"
                            Style="{StaticResource HeaderText}"
                            Text="{DynamicResource 当前值}" />
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="2"
                            Style="{StaticResource HeaderText}"
                            Text="{DynamicResource 单位}" />
                        <!--  市电电压  -->
                        <TextBlock
                            Grid.Row="1"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 市电电压}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            Style="{StaticResource ContentText}"
                            Text="{Binding HGRID_CYJ.MainsVoltage}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="2"
                            Style="{StaticResource ContentText}"
                            Text="V" />
                        <!--  市电功率  -->

                        <!--  市电频率  -->
                        <TextBlock
                            Grid.Row="3"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 市电频率}" />
                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="1"
                            Style="{StaticResource ContentText}"
                            Text="{Binding HGRID_CYJ.MainsFrequency}" />
                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="2"
                            Style="{StaticResource ContentText}"
                            Text="Hz" />


                    </Grid>
                </GroupBox>
            </ScrollViewer>

            <!--  系统信息与状态  -->
            <ScrollViewer
                Grid.Row="2"
                VerticalAlignment="Bottom"
                VerticalScrollBarVisibility="Auto">
                <GroupBox FontSize="16" Header="{DynamicResource 系统信息}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <!--  系统时间  -->
                        <!--<TextBlock Style="{StaticResource ContentText}" Text="{DynamicResource 系统时间}" />
                    <TextBlock
                        Grid.Column="2"
                        Grid.ColumnSpan="2"
                        Style="{StaticResource ContentText}"
                        Text="{Binding HGEN.SystemTime}" />-->
                        <!--  版本号  -->
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="2"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 版本号}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="3"
                            Style="{StaticResource ContentText}"
                            Text="{Binding HIMSG1.Version}" />
                        <!--  发布日期  -->
                        <TextBlock
                            Grid.Row="1"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 发布日期}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            Style="{StaticResource ContentText}"
                            Text="{Binding HIMSG1.ReleaseDate}" />
                        <!--  机器型号  -->
                        <TextBlock
                            Grid.Row="2"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 机器型号}" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="1"
                            Style="{StaticResource ContentText}"
                            Text="{Binding MachineModel}" />
                        <!--  机器类型  -->
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="2"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 机器类型}" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="3"
                            Style="{StaticResource ContentText}"
                            Text="{Binding MachineType}" />

                    </Grid>
                </GroupBox>
            </ScrollViewer>

        </Grid>
        <!--  第二行 第二列  -->
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="4*" MaxHeight="500" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>
            <!--  第一行 图标显示  -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <!--  市电  -->
                <Grid Grid.Row="0" Grid.Column="1">

                    <local:RingUC
                        FontSize="12"
                        PercentValue="{Binding ACTotalPwr}"
                        icon="&#xe61c;" />

                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Orientation="Horizontal">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Text="{Binding ACPowerVM}" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            FontSize="10"
                            Text="w" />
                    </StackPanel>
                </Grid>
                <!--  电池（左下）  -->
                <Grid Grid.Row="1" Grid.Column="0">
                    <local:RingUC
                        Grid.Row="1"
                        Grid.Column="2"
                        FontSize="12"
                        PercentValue="{Binding BattPercent}"
                        icon="&#xe603;" />

                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Orientation="Horizontal">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Text="{Binding BattPercent}" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            FontSize="10"
                            Text="%" />
                    </StackPanel>
                </Grid>
                <!--  中间  -->
                <StackPanel
                    Grid.Row="1"
                    Grid.Column="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                    <TextBlock
                        HorizontalAlignment="Center"
                        FontFamily="../Resource/Fonts/#iconfont"
                        FontSize="15"
                        Foreground="#FF1BD0E4"
                        Text="&#xe62f;" />
                    <StackPanel
                        Margin="10"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec63;" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec63;" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec63;" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec63;" />
                        <TextBlock
                            Margin="10,0"
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="30"
                            Text="&#xe6af;" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec62;" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec62;" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec62;" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="../Resource/Fonts/#iconfont"
                            FontSize="15"
                            Foreground="#FF1BD0E4"
                            Text="&#xec62;" />
                    </StackPanel>

                </StackPanel>
                <!--  右一  -->
                <Grid Grid.Row="1" Grid.Column="2">
                    <local:RingUC
                        Grid.Row="1"
                        Grid.Column="2"
                        FontSize="12"
                        PercentValue="{Binding InvTotalPwr}"
                        icon="&#xe973;" />

                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Orientation="Horizontal">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Text="{Binding HOP_PDF.ActivePwr}" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            FontSize="10"
                            Text="w" />
                    </StackPanel>
                </Grid>



            </Grid>
            <!--  第二行  -->
            <GroupBox Grid.Row="1" Header="Time">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <!--  标题  -->
                    <TextBlock
                        Grid.Row="0"
                        Style="{StaticResource HeaderText}"
                        Text="{DynamicResource 属性}" />
                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="1"
                        Style="{StaticResource HeaderText}"
                        Text="{DynamicResource 当前值}" />
                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="2"
                        Style="{StaticResource HeaderText}"
                        Text="{DynamicResource 单位}" />
                    <!--  强充时间  -->
                    <TextBlock
                        Grid.Row="1"
                        Style="{StaticResource ContentText}"
                        Text="{DynamicResource 强充时间}" />
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="1"
                        Style="{StaticResource ContentText}"
                        Text="{Binding HEEP1_CYJ.BoostTime}" />
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="2"
                        Style="{StaticResource ContentText}"
                        Text="" />
                    <!--  逆变时间  -->
                    <TextBlock
                        Grid.Row="2"
                        Style="{StaticResource ContentText}"
                        Text="{DynamicResource 逆变时间}" />
                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="1"
                        Style="{StaticResource ContentText}"
                        Text="{Binding HEEP1_CYJ.InvTime}" />
                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="2"
                        Style="{StaticResource ContentText}"
                        Text="" />
                    <!--  带载时间  -->
                    <!--<TextBlock
                        Grid.Row="3"
                        Style="{StaticResource ContentText}"
                        Text="{DynamicResource 带载时间}" />
                    <TextBlock
                        Grid.Row="3"
                        Grid.Column="1"
                        Style="{StaticResource ContentText}"
                        Text="{Binding HEEP1_CYJ.LoadTime}" />
                    <TextBlock
                        Grid.Row="3"
                        Grid.Column="2"
                        Style="{StaticResource ContentText}"
                        Text="" />-->
                </Grid>
            </GroupBox>


        </Grid>
        <!--  第二行 第三列  -->
        <Grid
            Grid.Row="1"
            Grid.Column="2"
            Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <GroupBox Header="{DynamicResource 输出}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <!--  标题  -->
                    <TextBlock
                        Grid.Row="0"
                        Style="{StaticResource HeaderText}"
                        Text="{DynamicResource 属性}" />
                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="1"
                        Style="{StaticResource HeaderText}"
                        Text="{DynamicResource 当前值}" />
                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="2"
                        Style="{StaticResource HeaderText}"
                        Text="{DynamicResource 单位}" />
                    <!--  输出频率  -->
                    <TextBlock
                        Grid.Row="2"
                        Style="{StaticResource ContentText}"
                        Text="{DynamicResource 输出频率}" />
                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="1"
                        Style="{StaticResource ContentText}"
                        Text="{Binding HOP_PDF.OutFreq}" />
                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="2"
                        Style="{StaticResource ContentText}"
                        Text="Hz" />
                    <!--  视在功率  -->
                    <TextBlock
                        Grid.Row="3"
                        Style="{StaticResource ContentText}"
                        Text="{DynamicResource 输出视在功率}" />
                    <TextBlock
                        Grid.Row="3"
                        Grid.Column="1"
                        Style="{StaticResource ContentText}"
                        Text="{Binding HOP_PDF.ApparentPwr}" />
                    <TextBlock
                        Grid.Row="3"
                        Grid.Column="2"
                        Style="{StaticResource ContentText}"
                        Text="W" />
                    <!--  有功功率  -->
                    <TextBlock
                        Grid.Row="4"
                        Style="{StaticResource ContentText}"
                        Text="{DynamicResource 输出有功功率}" />
                    <TextBlock
                        Grid.Row="4"
                        Grid.Column="1"
                        Style="{StaticResource ContentText}"
                        Text="{Binding HOP_PDF.ActivePwr}" />
                    <TextBlock
                        Grid.Row="4"
                        Grid.Column="2"
                        Style="{StaticResource ContentText}"
                        Text="W" />
                    <!--  负载百分比  -->
                    <TextBlock
                        Grid.Row="5"
                        Style="{StaticResource ContentText}"
                        Text="{DynamicResource 负载百分比}" />
                    <TextBlock
                        Grid.Row="5"
                        Grid.Column="1"
                        Style="{StaticResource ContentText}"
                        Text="{Binding HOP_PDF.LoadPercent}" />
                    <TextBlock
                        Grid.Row="5"
                        Grid.Column="2"
                        Style="{StaticResource ContentText}"
                        Text="%" />
                    <!--  满载有功功率  -->
                    <TextBlock
                        Grid.Row="6"
                        Style="{StaticResource ContentText}"
                        Text="{DynamicResource 满载有功功率}" />
                    <TextBlock
                        Grid.Row="6"
                        Grid.Column="1"
                        Style="{StaticResource ContentText}"
                        Text="{Binding HOP_PDF.RatedPwr}" />
                    <TextBlock
                        Grid.Row="6"
                        Grid.Column="2"
                        Style="{StaticResource ContentText}"
                        Text="W" />
                    <!--  电感电流  -->
                    <TextBlock
                        Grid.Row="7"
                        Style="{StaticResource ContentText}"
                        Text="{DynamicResource 电感电流}" />
                    <TextBlock
                        Grid.Row="7"
                        Grid.Column="1"
                        Style="{StaticResource ContentText}"
                        Text="{Binding HOP_PDF.InductorCurr}" />
                    <TextBlock
                        Grid.Row="7"
                        Grid.Column="2"
                        Style="{StaticResource ContentText}"
                        Text="A" />
                    <!--  电感功率  -->

                    <!--  输出电压  -->
                    <TextBlock
                        Grid.Row="1"
                        Style="{StaticResource ContentText}"
                        Text="{DynamicResource 输出电压}" />
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="1"
                        Style="{StaticResource ContentText}"
                        Text="{Binding HOP_PDF.OutVolt}" />
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="2"
                        Style="{StaticResource ContentText}"
                        Text="V" />

                </Grid>
            </GroupBox>
            <ScrollViewer
                Grid.Row="1"
                VerticalAlignment="Bottom"
                VerticalScrollBarVisibility="Auto">
                <GroupBox FontSize="16" Header="{DynamicResource 机器状态}">
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>



                        <!--  故障代码  -->
                        <TextBlock
                            Grid.Row="1"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 故障代码}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            Style="{StaticResource ContentText}"
                            Text="{Binding HSTS_CYJ.FaultCode}" />
                        <!--  模式  -->
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="2"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 模式}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="3"
                            Style="{StaticResource ContentText}"
                            Text="{Binding HSTS_CYJ.Mode}" />
                        <!--  逆变温度  -->
                        <TextBlock
                            Grid.Row="2"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 逆变温度}" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="1"
                            Style="{StaticResource ContentText}"
                            Text="{Binding HTEMP_PDF.InvTemp}" />
                        <!--  当前最高温度  -->
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="2"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 当前最高温度}" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="3"
                            Style="{StaticResource ContentText}"
                            Text="{Binding HTEMP_PDF.MaxTemp}" />
                        <!--  电池未接  -->
                        <TextBlock
                            Grid.Row="3"
                            Style="{StaticResource ContentText}"
                            Text="{DynamicResource 电池未接}" />
                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="1"
                            Style="{StaticResource ContentText}"
                            Text="{Binding HSTS_CYJ.BattDisconnected}" />
                        <!--  输出过载  -->
                        <TextBlock
                            Grid.Row="3"
